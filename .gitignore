# --- WordPress / site-specific generated content ---
# Sensitive environment-specific config
/wp-config.php

# Uploads & runtime-generated content
/wp-content/uploads/
/wp-content/upgrade/
/wp-content/cache/
/wp-content/backup-db/
/wp-content/backup*
/wp-content/backups/
/wp-content/ai1wm-backups/
/wp-content/updraft/
/wp-content/wflogs/

# Cache plugin drop-ins (commonly generated)
/wp-content/advanced-cache.php
/wp-content/object-cache.php
/wp-content/wp-cache-config.php
/wp-content/sunrise.php

# Common log files
/wp-content/debug.log
/error_log
/php_errorlog
*.log

# Optional: language packs are usually generated by WordPress updates
/wp-content/languages/

# --- Dependency/build artifacts (if you use them) ---
/vendor/
/node_modules/
/bower_components/
/dist/
/build/
/.parcel-cache/
/.next/
/.nuxt/
/.cache/

# --- Editor/OS cruft ---
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains
.idea/

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store

# Linux
*~

# Vim/Swap
*.swp
*.swo

# --- Local env files ---
.env
.env.*

# --- PHP tooling cache ---
.phpunit.result.cache
